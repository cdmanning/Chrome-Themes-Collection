{
  "manifest_version": 3,
  "version": "1.0.1",
  "name": "The Ringed Giant",
  "description": "An awe-inspiring view of Saturn and its rings adrift in the vast emptiness of space.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "theme": {
    "images": {
      "theme_ntp_background": "images/background.png"
    },
    "colors": {
      "toolbar": [165, 145, 115],

      "frame": [15, 15, 15],
      "frame_inactive": [15, 15, 15],
      "background_tab": [15, 15, 15],
      "button_background": [15, 15, 15],
      "omnibox_background": [15, 15, 15],

      "tab_text": [20, 15, 10],
      "bookmark_text": [20, 15, 10],
      "toolbar_button_icon": [20, 15, 10],

      "omnibox_text": [235, 230, 220],
      "caption_text": [235, 230, 220],

      "ntp_link": [210, 190, 150],
      "ntp_background": [15, 15, 15],
      "tab_background_text": [180, 170, 150],
      "tab_background_text_inactive": [180, 170, 150]
    }, 
    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}