{
  "manifest_version": 3,
  "version": "1.0.1",
  "name": "The Lonely Spirit",
  "description": "A simple pattern theme representing the spirit No-Face from Studio Ghibli's 'Spirited Away'.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "theme": {
    "images": {
      "theme_ntp_background": "images/background.png"
    },
    "colors": {
      "toolbar": [95, 75, 115],

      "frame": [65, 50, 80],
      "frame_inactive": [65, 50, 80],
      "background_tab": [65, 50, 80],
      "button_background": [65, 50, 80],
      "omnibox_background": [65, 50, 80],

      "tab_text": [245, 245, 245],
      "omnibox_text": [245, 245, 245],
      "bookmark_text": [245, 245, 245],
      "toolbar_button_icon": [245, 245, 245],

      "ntp_link": [200, 180, 230],
      "ntp_background": [45, 35, 55],
      "tab_background_text": [210, 200, 220],
      "tab_background_text_inactive": [210, 200, 220]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat": "repeat",
      "ntp_logo_alternate": 1
    }
  }
}