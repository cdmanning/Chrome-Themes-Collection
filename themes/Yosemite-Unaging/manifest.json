{
  "manifest_version": 3,
  "version": "1.0.1",
  "name": "Yosemite Unaging",
  "description": "A majestic landscape theme featuring the granite cliffs and evergreen forests of Yosemite.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "theme": {
    "images": {
      "theme_ntp_background": "images/background.png"
    },
    "colors": {
      "toolbar": [60, 95, 115],

      "frame": [40, 55, 45],
      "frame_inactive": [40, 55, 45],
      "background_tab": [40, 55, 45],
      "button_background": [40, 55, 45],
      "omnibox_background": [40, 55, 45],

      "tab_text": [245, 245, 245],
      "omnibox_text": [245, 245, 245],
      "bookmark_text": [245, 245, 245],
      "toolbar_button_icon": [245, 245, 245],

      "ntp_link": [135, 175, 145],
      "ntp_background": [20, 25, 20],
      "tab_background_text": [200, 200, 200],
      "tab_background_text_inactive": [200, 200, 200]
    }, 
    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}