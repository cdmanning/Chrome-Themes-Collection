{
  "manifest_version": 3,
  "version": "1.0.1",
  "name": "Neural Connections",
  "description": "A tech inspired theme highlighting glowing blue nodes and connections.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "theme": {
    "images": {
      "theme_ntp_background": "images/background.png"
    },
    "colors": {
      "toolbar": [0, 100, 250],

      "frame": [10, 15, 50],
      "frame_inactive": [10, 15, 50],
      "background_tab": [10, 15, 50],
      "button_background": [10, 15, 50],
      "omnibox_background": [10, 15, 50],

      "tab_text": [248, 248, 248],
      "omnibox_text": [248, 248, 248],
      "bookmark_text": [248, 248, 248],
      "toolbar_button_icon": [248, 248, 248],

      "ntp_link": [0, 200, 255],
      "ntp_background": [5, 5, 20],
      "tab_background_text": [160, 180, 220],
      "tab_background_text_inactive": [160, 180, 220]
    },
    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}