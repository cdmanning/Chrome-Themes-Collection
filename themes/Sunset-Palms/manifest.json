{
  "manifest_version": 3,
  "version": "1.0.1",
  "name": "Sunset Palms",
  "description": "A vibrant, high-contrast sunset theme with deep purples and oranges.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "theme": {
    "images": {
      "theme_ntp_background": "images/background.png"
    },
    "colors": {
      "toolbar": [145, 64, 98],

      "frame": [117, 52, 78],
      "background_tab": [117, 52, 78],
      "frame_inactive": [117, 52, 78],
      "button_background": [117, 52, 78],
      "omnibox_background": [117, 52, 78],

      "tab_text": [248, 248, 248],
      "omnibox_text": [248, 248, 248],
      "bookmark_text": [248, 248, 248],
      "toolbar_button_icon": [248, 248, 248],
      
      "ntp_link": [255, 200, 220],
      "ntp_background": [45, 20, 30],
      "tab_background_text": [210, 210, 210],
      "tab_background_text_inactive": [210, 210, 210]
    },
    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}