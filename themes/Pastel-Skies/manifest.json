{
  "manifest_version": 3,
  "version": "1.0.1",
  "name": "Pastel Skies",
  "description": "A calming cityscape with soft pink horizons and purple twilight.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "theme": {
    "images": {
      "theme_ntp_background": "images/background.png"
    },
    "colors": {
      "toolbar": [195, 145, 175],

      "frame": [155, 135, 185],
      "frame_inactive": [155, 135, 185],
      "background_tab": [155, 135, 185],
      "button_background": [155, 135, 185],
      "omnibox_background": [155, 135, 185],

      "tab_text": [248, 248, 248],
      "omnibox_text": [248, 248, 248],
      "bookmark_text": [248, 248, 248],
      "toolbar_button_icon": [248, 248, 248],

      "ntp_link": [255, 180, 220],
      "ntp_background": [60, 45, 100],
      "tab_background_text": [230, 210, 245],
      "tab_background_text_inactive": [230, 210, 245]
    },
    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}